<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>ca.uottawa.csmlab.symboleo</groupId>
    <artifactId>symboleo-cli</artifactId>
    <version>1.0.0</version>
    <packaging>jar</packaging>

    <name>Symboleo(AC) Headless CLI</name>
    <description>
        Standalone command-line validator/generator for the Symboleo / SymboleoAC
        Xtext language. Loads a *.symboleo file, runs the parser plus all @Check
        validations, and writes the resulting diagnostics to a file. Does not
        require Eclipse at runtime.
    </description>

    <properties>
        <maven.compiler.source>17</maven.compiler.source>
        <maven.compiler.target>17</maven.compiler.target>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>

        <!-- Xtext + Xtend + MWE2 must be a matched set. 2.36/2.22 are the
             newest mutually-compatible versions on Maven Central. The
             "generated by Xtext 2.25.0" headers in the runtime project's
             checked-in sources are cosmetic; MWE2 will regenerate parser/
             EMF model fresh against the 2.36 API on each build. -->
        <xtext.version>2.36.0</xtext.version>
        <xtend.version>2.36.0</xtend.version>
        <mwe2.version>2.22.0</mwe2.version>

        <!-- Path to the existing Eclipse runtime project (sibling of cli/). -->
        <runtime.project.dir>${project.basedir}/../ca.uottawa.csmlab.symboleo</runtime.project.dir>
    </properties>

    <dependencies>
        <!-- Xtext runtime -->
        <dependency>
            <groupId>org.eclipse.xtext</groupId>
            <artifactId>org.eclipse.xtext</artifactId>
            <version>${xtext.version}</version>
        </dependency>
        <dependency>
            <groupId>org.eclipse.xtext</groupId>
            <artifactId>org.eclipse.xtext.xbase</artifactId>
            <version>${xtext.version}</version>
        </dependency>
        <dependency>
            <groupId>org.eclipse.xtext</groupId>
            <artifactId>org.eclipse.xtext.xbase.lib</artifactId>
            <version>${xtext.version}</version>
        </dependency>
        <dependency>
            <groupId>org.eclipse.xtend</groupId>
            <artifactId>org.eclipse.xtend.lib</artifactId>
            <version>${xtend.version}</version>
        </dependency>

        <!-- Guice (Xtext uses it for DI) -->
        <dependency>
            <groupId>com.google.inject</groupId>
            <artifactId>guice</artifactId>
            <version>5.0.1</version>
        </dependency>

        <!-- log4j 1.2 API shim (the runtime project imports org.apache.log4j) -->
        <dependency>
            <groupId>org.apache.logging.log4j</groupId>
            <artifactId>log4j-1.2-api</artifactId>
            <version>2.17.2</version>
        </dependency>
        <dependency>
            <groupId>org.apache.logging.log4j</groupId>
            <artifactId>log4j-core</artifactId>
            <version>2.17.2</version>
        </dependency>

        <!-- Tiny JSON writer; no transitive deps. -->
        <dependency>
            <groupId>org.json</groupId>
            <artifactId>json</artifactId>
            <version>20231013</version>
        </dependency>
    </dependencies>

    <build>
        <!-- Xtext-generated metadata that must be on the runtime classpath
             (the parser code does classpath:/...Symboleo.xmi lookups, etc.). -->
        <resources>
            <resource>
                <directory>${runtime.project.dir}/src-gen</directory>
                <includes>
                    <include>**/*.xmi</include>
                    <include>**/*.xtextbin</include>
                    <include>**/*.tokens</include>
                    <include>**/*.g</include>
                </includes>
            </resource>
            <resource>
                <directory>src/main/resources</directory>
            </resource>
        </resources>
        <plugins>

            <!-- 1) Add the runtime project's sources (hand-written + generated) to this build. -->
            <plugin>
                <groupId>org.codehaus.mojo</groupId>
                <artifactId>build-helper-maven-plugin</artifactId>
                <version>3.4.0</version>
                <executions>
                    <execution>
                        <id>add-runtime-sources</id>
                        <phase>generate-sources</phase>
                        <goals>
                            <goal>add-source</goal>
                        </goals>
                        <configuration>
                            <sources>
                                <source>${runtime.project.dir}/src</source>
                                <source>${runtime.project.dir}/src-gen</source>
                                <source>${runtime.project.dir}/xtend-gen</source>
                            </sources>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

            <!-- 2) MWE2 (Xtext language generator) is NOT run from Maven.
                 The expected output (parser, EMF model, *StandaloneSetupGenerated)
                 must exist in ../ca.uottawa.csmlab.symboleo/src-gen/ before the
                 build starts. Bootstrap by opening the project in Eclipse with
                 the Xtext SDK and running GenerateSymboleo.mwe2 (Run As → MWE2
                 Workflow). See README for details. -->

            <!-- 3) Xtend compilation is also NOT run from Maven, for the same
                 reason as MWE2: xtend-maven-plugin refuses source dirs that are
                 not children of the project folder. The bootstrap step that
                 generated src-gen/ also populates xtend-gen/ with the Java
                 translations of the .xtend sources. We simply add xtend-gen/
                 to the Java compile sources below. -->

            <!-- 4) Standard Java compile (on src + src-gen + xtend-gen). -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>3.11.0</version>
                <configuration>
                    <source>17</source>
                    <target>17</target>
                </configuration>
            </plugin>

            <!-- 5) Build an executable fat jar. -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-shade-plugin</artifactId>
                <version>3.5.0</version>
                <executions>
                    <execution>
                        <phase>package</phase>
                        <goals>
                            <goal>shade</goal>
                        </goals>
                        <configuration>
                            <createDependencyReducedPom>false</createDependencyReducedPom>
                            <shadedArtifactAttached>true</shadedArtifactAttached>
                            <shadedClassifierName>all</shadedClassifierName>
                            <transformers>
                                <transformer
                                    implementation="org.apache.maven.plugins.shade.resource.ManifestResourceTransformer">
                                    <mainClass>ca.uottawa.csmlab.symboleo.cli.Cli</mainClass>
                                </transformer>
                                <transformer
                                    implementation="org.apache.maven.plugins.shade.resource.ServicesResourceTransformer"/>
                                <!-- Multiple Eclipse jars ship a top-level plugin.properties;
                                     without merging, shade keeps only one (Xtext's) and
                                     EMF's _UI_DiagnosticRoot_diagnostic lookup fails,
                                     causing Diagnostician to throw MissingResourceException
                                     which IResourceValidator silently swallows along with
                                     all the actual @Check diagnostics. Append all of them. -->
                                <transformer
                                    implementation="org.apache.maven.plugins.shade.resource.AppendingTransformer">
                                    <resource>plugin.properties</resource>
                                </transformer>
                            </transformers>
                            <filters>
                                <filter>
                                    <artifact>*:*</artifact>
                                    <excludes>
                                        <exclude>META-INF/*.SF</exclude>
                                        <exclude>META-INF/*.DSA</exclude>
                                        <exclude>META-INF/*.RSA</exclude>
                                        <exclude>module-info.class</exclude>
                                    </excludes>
                                </filter>
                            </filters>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>
</project>
